<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_task_row"
    android:layout_width="match_parent"
    android:layout_height="24dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="1dp"
    android:paddingBottom="1dp">

    <TextView
        android:id="@+id/widget_task_time"
        android:layout_width="42dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:textColor="#FF67E8F9"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_task_category"
        android:layout_width="54dp"
        android:layout_height="match_parent"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:textColor="#FFE9D5FF"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/widget_task_title"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_task_done"
        android:layout_width="28dp"
        android:layout_height="22dp"
        android:background="@drawable/qdone_widget_done_button"
        android:gravity="center"
        android:text="✓"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
